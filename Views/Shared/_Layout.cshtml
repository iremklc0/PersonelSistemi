@using System.Linq
<!DOCTYPE html>
<html lang="tr" class="dark-side">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Otek Modüler Sistem</title>
    <link rel="stylesheet" href="https://cdn.metroui.org.ua/v4.3.2/css/metro-all.min.css" />
    <link rel="stylesheet" href="~/css/otek-sistem.css" />
    <style>
        html body .button.primary,
        html body .button.success,
        html body .button.warning,
        html body .button.alert,
        html body .button.secondary,
        html body .button.info {
            background-color: var(--tema-arkaplan) !important;
            border-color: var(--tema-arkaplan) !important;
            color: var(--tema-yazi) !important;
            box-shadow: none !important;
            outline: none !important;
        }

        html body .button:hover {
            background-color: var(--tema-vurgu) !important;
            border-color: var(--tema-vurgu) !important;
            opacity: 1 !important;
        }

        .galeri-alani {
            padding-top: 15px !important;
            padding-left: 10px !important;
            padding-right: 10px !important;
        }
    </style>
</head>
<body>

    <div data-role="appbar" data-expand-point="md" class="dinamik-tema-arkaplan " style="z-index: 10000;">
        <a href="#" class="brand dinamik-kirmizi menuler-tiklama " onclick="toggleKendiPanelimiz(); return false;" style="width: 80px; text-align: center; justify-content: center; cursor: pointer;">
            <b>OTEK</b>
        </a>
        <a href="/Home/Index" class="app-bar-item dinamik-kirmizi menuler-tiklama aktif-menu">
            <span class="name text-upper">Ana Sayfa</span>
        </a>

        <ul class="app-bar-menu">
            <li>
                <a href="javascript:void(0)" class="dropdown-toggle">Modüler Sistem</a>
                <ul class="d-menu">
                    <li><a href="#" onclick="medyaPenceresiAc(); return false;">Medya </a></li>
                    <li><a href="#" onclick="belgePenceresiAc(); return false;">Belge Yönetimi</a></li>
                </ul>
            </li>
            <li>
                <a href="javascript:void(0)" class="dropdown-toggle">Personel Yönetimi</a>
                <ul class="d-menu">
                    <li><a href="#" onclick="kutuAc('A Personelleri', '/Personel/Index'); return false;">A Personelleri</a></li>
                    <li><a href="#" onclick="kutuAc('B Personelleri', '/BPersonel/Index'); return false;">B Personelleri</a></li>
                </ul>
            </li>
            <li>
                <a href="javascript:void(0)" class="dropdown-toggle">İnşaat Modülü</a>
                <ul class="d-menu">
                    <li><a href="#" onclick="insaatListesiAc(); return false;">İnşaat Listesi</a></li>
                </ul>
            </li>
        </ul>

        <a href="#" id="pinButton" class="app-bar-item ml-auto" onclick="paneliSabitle(); return false;" title="Sabitle">
            <span class="mif-pin"></span>
        </a>
    </div>

    <div id="arka-plan-golgesi" class="panel-golgesi" onclick="toggleKendiPanelimiz()"></div>
    <div id="sol-profil-menusu" class="kendi-panelimiz ">
        <div class="text-center mt-5 mb-4">
            <span class="mif-user mif-5x fg-cyan"></span>
            <h3 class="mt-2 text-light mb-0">İrem</h3>
            <span class="fg-gray">Admin Profili</span>
        </div>
        <hr class="bg-gray" style="margin: 0 20px 20px 20px;">

        <div style="padding: 0 15px;">
            <p class="text-small fg-gray mb-2 pl-3" style="font-weight: bold;">Sistem Teması</p>
            <div class="d-flex flex-row align-items-center mb-4 pl-3" style="gap: 15px;">
                <input type="color" id="tema-renk-secici" value="#343a40" style="width: 45px; height: 40px; border: 2px solid #555; cursor: pointer; border-radius: 5px; padding: 0; background: transparent;" onchange="temaDegistir(this.value)" title="Renk Seç">
                <button class="button small alert outline" onclick="temayiSifirla()">Varsayılana Dön</button>
            </div>

            <a href="#" onclick="sifreDegistirAc(); return false;" class="profil-link mt-2">
                <span class="mif-key mif-lg mr-4"></span> Şifre Değiştir
            </a>
            <a href="/Login/CikisYap" class="profil-link cikis">
                <span class="mif-exit mif-lg mr-4"></span> Çıkış Yap
            </a>
        </div>
    </div>

    <div class="ana-icerik">
        <main role="main">@RenderBody()</main>
    </div>

    <div id="gorsel-overlay" onclick="gorselKapat()">
        <span id="gorsel-overlay-kapat" onclick="gorselKapat()">&#x2715;</span>
        <button type="button" id="gorsel-overlay-sil" class="button alert" onclick="dosyaSil(this.getAttribute('data-dosya'), event)">
            <span class="mif-bin"></span> Sil
        </button>
        <img id="gorsel-overlay-img" src="" alt="Önizleme" onclick="event.stopPropagation()" />
    </div>

    <div id="medya-icerik-sablonu" style="display:none;">
        <div class="medya-pencere-icerik">
            <div class="row">
                <div class="cell-md-4" style="border-right: 1px solid #eee; padding-right: 20px;">
                    <h5 class="mt-0">Yeni Resim Yükle</h5>
                    <p class="text-small fg-gray">Sadece fotoğraf (.jpg, .png) dosyalarınızı buradan yükleyebilirsiniz.</p>
                    <form class="dosya-yukle-form" action="/Medya/DosyaYukle" method="post" enctype="multipart/form-data">
                        <div class="form-group">
                            <input type="file" name="yuklenenDosyalar" multiple accept=".jpg,.jpeg,.png,.gif">
                        </div>
                        <div class="form-group mt-4">
                            <button type="submit" class="button success w-100">
                                <span class="mif-upload"></span> Sisteme Yükle
                            </button>
                        </div>
                    </form>
                </div>
                <div class="cell-md-8" style="padding-left: 20px;">
                    <div class="belge-liste-alani">
                        <h5 class="mt-0">Sistemdeki Fotoğraflar</h5>
                        <div class="galeri-alani mt-4">
                            @{
                                var uploadKlasoru = System.IO.Path.Combine(System.IO.Directory.GetCurrentDirectory(), "wwwroot", "uploads");
                                if (System.IO.Directory.Exists(uploadKlasoru))
                                {
                                    var tumDosyalar = new System.IO.DirectoryInfo(uploadKlasoru).GetFiles().OrderByDescending(f => f.CreationTime).ToList();
                                    var resimler = tumDosyalar.Where(d => d.Extension.ToLower() == ".jpg" || d.Extension.ToLower() == ".jpeg" || d.Extension.ToLower() == ".png" || d.Extension.ToLower() == ".gif").ToList();

                                    if (resimler.Count > 0)
                                    {
                                        foreach (var dosya in resimler)
                                        {
                                            var dosyaUrl = "/uploads/" + dosya.Name;
                                            <div class="dosya-kapsayici" style="position: relative; display: inline-block;">
                                                <div class="galeri-kutusu bg-light text-center" onclick="dosyaAc('@dosyaUrl', true, '@dosya.Name')" title="@dosya.Name">
                                                    <img src="@dosyaUrl" alt="@dosya.Name" />
                                                </div>
                                                <button type="button" class="button alert mini" style="position: absolute; top: -8px; right: -8px; padding: 0; width: 24px; height: 24px; border-radius: 50%; z-index: 15;" onclick="dosyaSil('@dosya.Name', event)" title="Sil">
                                                    <span class="mif-cross"></span>
                                                </button>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <p class="text-muted w-100 text-center mt-5"><i>Galeride henüz resim bulunmuyor.</i></p>
                                    }
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="belge-icerik-sablonu" style="display:none;">
        <div class="medya-pencere-icerik">
            <div class="row">
                <div class="cell-md-4" style="border-right: 1px solid #eee; padding-right: 20px;">
                    <h5 class="mt-0">Yeni Belge Yükle</h5>
                    <p class="text-small fg-gray">PDF, Word, Excel ve diğer belge formatlarını buradan yükleyebilirsiniz.</p>
                    <form class="dosya-yukle-form" action="/Medya/DosyaYukle" method="post" enctype="multipart/form-data">
                        <div class="form-group">
                            <input type="file" name="yuklenenDosyalar" multiple accept=".pdf,.doc,.docx,.xls,.xlsx,.zip,.rar,.mp4">
                        </div>
                        <div class="form-group mt-4">
                            <button type="submit" class="button primary w-100">
                                <span class="mif-upload"></span> Sisteme Yükle
                            </button>
                        </div>
                    </form>
                </div>
                <div class="cell-md-8" style="padding-left: 20px;">

                    <div class="belge-liste-alani">
                        <h5 class="mt-0">Sistemdeki Belgeler</h5>
                        <div class="galeri-alani mt-4">
                            @{
                                if (System.IO.Directory.Exists(uploadKlasoru))
                                {
                                    var tumDosyalar2 = new System.IO.DirectoryInfo(uploadKlasoru).GetFiles().OrderByDescending(f => f.CreationTime).ToList();
                                    var belgeler = tumDosyalar2.Where(d => d.Extension.ToLower() != ".jpg" && d.Extension.ToLower() != ".jpeg" && d.Extension.ToLower() != ".png" && d.Extension.ToLower() != ".gif").ToList();

                                    if (belgeler.Count > 0)
                                    {
                                        foreach (var dosya in belgeler)
                                        {
                                            var dosyaUrl = "/uploads/" + dosya.Name;
                                            var uzanti = dosya.Extension.ToLower();

                                            string ikonSinifi = "mif-file-empty"; string renkSinifi = "fg-gray";
                                            if (uzanti == ".pdf") { ikonSinifi = "mif-file-pdf"; renkSinifi = "fg-red"; }
                                            else if (uzanti == ".doc" || uzanti == ".docx") { ikonSinifi = "mif-file-word"; renkSinifi = "fg-blue"; }
                                            else if (uzanti == ".xls" || uzanti == ".xlsx") { ikonSinifi = "mif-file-excel"; renkSinifi = "fg-green"; }
                                            else if (uzanti == ".mp4" || uzanti == ".avi") { ikonSinifi = "mif-file-play"; renkSinifi = "fg-cyan"; }
                                            else if (uzanti == ".zip" || uzanti == ".rar") { ikonSinifi = "mif-file-archive"; renkSinifi = "fg-brown"; }

                                            <div class="dosya-kapsayici" style="position: relative; display: inline-block;">
                                                <div class="galeri-kutusu bg-light text-center" onclick="dosyaAc('@dosyaUrl', false, '@dosya.Name')" title="@dosya.Name">
                                                    <div class="d-flex flex-column flex-justify-center h-100 @renkSinifi">
                                                        <span class="@ikonSinifi mif-3x"></span>
                                                        <span class="text-small mt-2 text-truncate" style="padding: 0 5px;">@dosya.Extension</span>
                                                    </div>
                                                </div>
                                                <button type="button" class="button alert mini" style="position: absolute; top: -8px; right: -8px; padding: 0; width: 24px; height: 24px; border-radius: 50%; z-index: 15;" onclick="dosyaSil('@dosya.Name', event)" title="Sil">
                                                    <span class="mif-cross"></span>
                                                </button>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <p class="text-muted w-100 text-center mt-5"><i>Sistemde henüz belge bulunmuyor.</i></p>
                                    }
                                }
                            }
                        </div>
                    </div>

                    <div class="belge-onizleme-alani" style="display:none; flex-direction: column;">
                        <div class="d-flex flex-align-center mb-3">
                            <button class="button secondary outline rounded small mr-3" onclick="onizlemeyiKapat(this)">
                                <span class="mif-arrow-left"></span> Geri
                            </button>
                            <h5 class="mt-0 mb-0 text-bold belge-onizleme-baslik"></h5>
                        </div>
                        <div class="belge-onizleme-icerik bg-white p-4" style="flex-grow: 1; height: 420px; overflow-y: auto; border: 1px solid #e1e1e1; border-radius: 5px;">
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.metroui.org.ua/v4.3.2/js/metro.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/mammoth/1.4.21/mammoth.browser.min.js"></script>
    <script src="/js/layout.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>