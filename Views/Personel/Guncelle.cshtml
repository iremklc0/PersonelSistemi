@model PersonelSistemi.Models.Personel
@{
    Layout = "~/Views/Shared/_PencereLayout.cshtml";
}

<div class="container" style="margin-top: 20px;">
    <h2>Personel Bilgilerini Güncelle</h2>
    <hr />

    <form asp-controller="Personel" asp-action="Guncelle" method="post">

        <input type="hidden" asp-for="objectid" />

        <div asp-validation-summary="ModelOnly" class="fg-red mb-2 text-bold"></div>

        <div class="row mb-4">
            <div class="cell-md-6">
                <label>Adı</label>
                <input type="text" data-role="input" asp-for="adi" required>
                    <span asp-validation-for="adi" class="fg-red text-small"></span>
                </div>

                <div class="cell-md-6">
                    <label>Soyadı</label>
                    <input type="text" data-role="input" asp-for="soyadi" required>
                        <span asp-validation-for="soyadi" class="fg-red text-small"></span>
                    </div>
                </div>

                <div class="row mt-4">
                    <div class="cell-md-12">
                        <button type="submit" class="button warning"><span class="mif-loop2"></span> Bilgileri Güncelle</button>
                        <a href="/Personel/Index" class="button secondary outline">İptal</a>
                    </div>
                </div>

            </form>
        </div>