@{
    Layout = null;
}
@{
    var kolonlar = ViewBag.Kolonlar as List<GridKolonModel>;
    var veriler = ViewBag.Veriler as List<Dictionary<string, object>>;
    var baslik = ViewBag.Baslik as string;
}

<link rel="stylesheet" href="https://cdn.metroui.org.ua/v4.3.2/css/metro-all.min.css" />
<style>
    body {
        font-family: Arial, sans-serif;
        padding: 15px;
        background: #f5f5f5;
    }

    .grid-baslik {
        font-size: 18px;
        font-weight: bold;
        margin-bottom: 15px;
        color: #2c3e50;
    }

    .filtre-alani {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-bottom: 12px;
    }

        .filtre-alani input {
            padding: 6px 10px;
            border: 1px solid #ddd;
            border-radius: 4px;
            font-size: 13px;
        }

    table {
        width: 100%;
        border-collapse: collapse;
        background: white;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 2px 6px rgba(0,0,0,0.08);
    }

    thead tr {
        background: #2c3e50;
        color: white;
    }

    th {
        padding: 10px 12px;
        text-align: left;
        font-size: 13px;
        cursor: pointer;
        user-select: none;
    }

        th:hover {
            background: #34495e;
        }

    td {
        padding: 10px 12px;
        font-size: 13px;
        border-bottom: 1px solid #eee;
    }

    tr:hover {
        background: #f0f4f8;
    }

    .durum-badge {
        padding: 3px 8px;
        border-radius: 12px;
        font-size: 12px;
        font-weight: bold;
    }

    .durum-0 {
        background: #fdecea;
        color: #e74c3c;
    }

    .durum-1 {
        background: #fef9e7;
        color: #f39c12;
    }

    .durum-2 {
        background: #eafaf1;
        color: #27ae60;
    }

    .btn-rapor {
        padding: 4px 10px;
        background: #3498db;
        color: white;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-size: 12px;
    }

        .btn-rapor:hover {
            background: #2980b9;
        }

    .progress-bar {
        background: #f0f0f0;
        border-radius: 4px;
        height: 6px;
        min-width: 80px;
    }

    .progress-fill {
        height: 6px;
        border-radius: 4px;
    }
</style>

<div class="grid-baslik">🏗️ @baslik</div>

<div class="filtre-alani">
    @if (kolonlar != null)
    {
        foreach (var kolon in kolonlar.Where(k => k.FiltrelenebilirMi))
        {
            <input type="text" placeholder="@kolon.Baslik ara..." data-kolon="@kolon.VeriAlani" class="filtre-input" oninput="filtreUygula()" />
        }
    }
</div>

<table id="insaatTablosu">
    <thead>
        <tr>
            @if (kolonlar != null)
            {
                foreach (var kolon in kolonlar)
                {
                    <th onclick="sirala('@kolon.VeriAlani')" data-kolon="@kolon.VeriAlani">
                        @kolon.Baslik @(kolon.SiralanabilirMi ? "⇅" : "")
                    </th>
                }
            }
            <th>İşlem</th>
        </tr>
    </thead>
    <tbody id="insaatTbody">
        @if (veriler != null)
        {
            foreach (var satir in veriler)
            {
                var durumId = satir.ContainsKey("durumId") ? satir["durumId"].ToString() : "1";
                var durumAdi = satir.ContainsKey("durumAdi") ? satir["durumAdi"].ToString() : "";
                var yuzde = satir.ContainsKey("tamamlanmaYuzdesi") ? satir["tamamlanmaYuzdesi"].ToString()!.Replace("%", "") : "0";
                var durumRenk = durumId == "0" ? "#e74c3c" : durumId == "1" ? "#f39c12" : "#27ae60";
                var id = satir.ContainsKey("id") ? satir["id"].ToString() : "0";

                <tr data-id="@id">
                    @foreach (var kolon in kolonlar!)
                    {
                        var deger = satir.ContainsKey(kolon.VeriAlani) ? satir[kolon.VeriAlani]?.ToString() ?? "" : "";
                        if (kolon.VeriAlani == "durumAdi")
                        {
                            <td><span class="durum-badge durum-@durumId">@deger</span></td>
                        }
                        else if (kolon.VeriAlani == "tamamlanmaYuzdesi")
                        {
                            <td>
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width:@yuzde%; background:@durumRenk;"></div>
                                </div>
                                <span style="font-size:11px; color:#999;">@deger</span>
                            </td>
                        }
                        else
                        {
                            <td>@deger</td>
                        }
                    }
                    <td>
                        <button class="btn-rapor" onclick="raporAc(@id)">📋 Durum Raporu</button>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    var tumSatirlar = [];
    var siralamaYon = {};

    $(document).ready(function () {
        tumSatirlar = $('#insaatTbody tr').toArray();
    });

    function filtreUygula() {
        var filtreler = {};
        $('.filtre-input').each(function () {
            var kolon = $(this).data('kolon');
            var deger = $(this).val().toLowerCase();
            if (deger) filtreler[kolon] = deger;
        });

        var gorunenler = tumSatirlar.filter(function (satir) {
            return Object.keys(filtreler).every(function (kolon) {
                var hucre = $(satir).find('td[data-kolon="' + kolon + '"]');
                if (hucre.length === 0) {
                    var index = $('th[data-kolon="' + kolon + '"]').index();
                    hucre = $(satir).find('td').eq(index);
                }
                return hucre.text().toLowerCase().indexOf(filtreler[kolon]) !== -1;
            });
        });

        $('#insaatTbody').empty();
        gorunenler.forEach(function (satir) { $('#insaatTbody').append(satir); });
        tumSatirlar.filter(function (s) { return gorunenler.indexOf(s) === -1; })
            .forEach(function (satir) { $(satir).hide(); });
    }

    function sirala(kolon) {
        siralamaYon[kolon] = siralamaYon[kolon] === 'asc' ? 'desc' : 'asc';
        var yon = siralamaYon[kolon];
        var kolonIndex = $('th[data-kolon="' + kolon + '"]').index();

        var satirlar = $('#insaatTbody tr').toArray();
        satirlar.sort(function (a, b) {
            var aVal = $(a).find('td').eq(kolonIndex).text().trim();
            var bVal = $(b).find('td').eq(kolonIndex).text().trim();
            return yon === 'asc' ? aVal.localeCompare(bVal, 'tr') : bVal.localeCompare(aVal, 'tr');
        });
        $('#insaatTbody').empty();
        satirlar.forEach(function (s) { $('#insaatTbody').append(s); });
    }

    function raporAc(id) {
        if (window.parent && window.parent.insaatRaporuGosterById) {
            window.parent.insaatRaporuGosterById(id);
        }
    }
</script>